# Fun-ASR (Alibaba DashScope) 语音识别配置
# 复制此文件为 .env 并填入你的配置

# API Key (从阿里云百炼控制台获取: https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=your_api_key_here

# 可选: 自定义 WebSocket 端点 (默认: wss://dashscope.aliyuncs.com/api-ws/v1/inference/)
# FUN_ASR_ENDPOINT=wss://dashscope.aliyuncs.com/api-ws/v1/inference/